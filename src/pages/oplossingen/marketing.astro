---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="AI-gedreven B2B-marketing — Eén systeem voor commerciële groei | Optimaal Groeien"
  description="Van SEO tot social media en van content tot AI-automatisering — Optimaal Groeien bouwt en beheert je volledige marketingsysteem als externe commerciële afdeling."
  canonical="https://optimaalgroeien.nl/oplossingen/marketing"
>

  <!-- HERO -->
  <section class="hero-warm pt-36 pb-24 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-brand-accent/5 blur-[140px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[280px] h-[280px] rounded-full bg-amber-200/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">

        <!-- Left: copy -->
        <div class="lg:w-1/2 w-full">
          <div class="label-pill">
            <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
            AI-gedreven marketingsysteem
          </div>
          <h1 class="text-[2rem] sm:text-[2.5rem] lg:text-[3.25rem] font-display font-bold text-brand-primary leading-[1.1] tracking-tight mb-5">
            Marketing die samenwerkt.<br />
            <span class="text-brand-accent">Versneld door AI.</span>
          </h1>
          <p class="text-base sm:text-lg text-brand-ink/70 max-w-xl leading-relaxed mb-8">
            SEO, content, social media en AI-automatisering — wij bouwen het als één systeem dat voor jou werkt. Geen losse bureaus, geen versnipperd budget. Eén geïntegreerde aanpak die elke dag nieuwe aanvragen genereert.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
              class="btn-primary !py-4 !px-9 text-sm w-full sm:w-auto justify-center">
              Plan een gratis analyse
            </a>
            <a href="#systeem"
              class="w-full sm:w-auto px-7 py-4 bg-white text-brand-primary rounded-2xl font-display font-bold transition-all hover:scale-[1.02] border-2 border-amber-100 shadow-sm flex items-center justify-center gap-2 text-sm">
              Wat wij doen
            </a>
          </div>

          <!-- Stats row -->
          <div class="flex gap-6 sm:gap-8 mt-10 pt-8 border-t border-amber-100">
            <div>
              <div class="text-2xl sm:text-3xl font-display font-black text-brand-primary">+150%</div>
              <div class="text-[10px] text-brand-ink/50 font-bold uppercase tracking-widest mt-1">organisch bereik</div>
            </div>
            <div class="w-px bg-amber-100"></div>
            <div>
              <div class="text-2xl sm:text-3xl font-display font-black text-brand-primary">3×</div>
              <div class="text-[10px] text-brand-ink/50 font-bold uppercase tracking-widest mt-1">meer aanvragen</div>
            </div>
            <div class="w-px bg-amber-100"></div>
            <div>
              <div class="text-2xl sm:text-3xl font-display font-black text-brand-primary">30d</div>
              <div class="text-[10px] text-brand-ink/50 font-bold uppercase tracking-widest mt-1">van start tot live</div>
            </div>
          </div>
        </div>

        <!-- Right: image -->
        <div class="lg:w-1/2 w-full relative">
          <div class="relative rounded-[24px] overflow-hidden shadow-2xl shadow-brand-primary/10">
            <img
              src="/images/macbook.webp"
              alt="Marketing systeem dashboard — Optimaal Groeien"
              class="w-full h-48 sm:h-auto object-cover"
              loading="eager"
              width="640"
              height="440"
            />
            <div class="absolute bottom-4 left-4 right-4">
              <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-3 sm:p-4 shadow-xl border border-amber-50 flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-brand-accent/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-display font-bold text-brand-primary">Alle kanalen. Eén systeem.</div>
                  <div class="text-[10px] text-brand-ink/50 font-medium">SEO · Content · Social media · AI · Ads</div>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -top-6 -right-6 w-28 h-28 rounded-full bg-brand-lime/20 blur-2xl pointer-events-none"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION 2: Pijnpunten -->
  <section class="py-20 sm:py-24 px-4 sm:px-6 bg-white">
    <div class="max-w-7xl mx-auto">

      <div class="flex flex-col lg:flex-row gap-12 items-start mb-16">
        <div class="lg:w-1/2">
          <div class="label-pill">Herkenbare pijnpunten</div>
          <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
            Waarom marketing voor B2B-bedrijven<br /><span class="text-brand-accent">zelden oplevert wat het belooft.</span>
          </h2>
        </div>
        <div class="lg:w-1/2 lg:pt-12">
          <p class="text-lg text-brand-ink/70 leading-relaxed font-light">
            De meeste bedrijven doen een beetje van alles — zonder samenhang, zonder systeem. Het budget verdwijnt, maar de aanvragen komen niet. Herkenbaar? Dan is dit voor jou.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {[
          {
            nr: "01",
            title: "Activiteiten zonder resultaat.",
            desc: "Je post en publiceert, maar de aanvragen blijven uit. Er is geen systeem dat de losse kanalen aan elkaar koppelt.",
          },
          {
            nr: "02",
            title: "Ieder bureau zijn eigen silo.",
            desc: "Je SEO-bureau weet niet wat je social-bureau doet. Er is geen gezamenlijke strategie en niemand die het totaalplaatje bewaakt.",
          },
          {
            nr: "03",
            title: "Geen idee wat werkt.",
            desc: "Likes en impressies vertellen niets. Je weet niet welk kanaal klanten oplevert en waar je budget het hardst werkt.",
          },
          {
            nr: "04",
            title: "AI blijft liggen.",
            desc: "Je weet dat AI iets kan doen voor je marketing — maar een structurele aanpak ontbreekt. De concurrent is al bezig.",
          },
        ].map(item => (
          <div class="warm-card p-8 flex gap-6 items-start group hover:shadow-lg transition-all duration-300 overflow-hidden">
            <div
              class="text-[4.5rem] font-display font-black text-amber-100 group-hover:text-brand-accent/15 transition-colors duration-500 select-none leading-none shrink-0 pt-1"
              aria-hidden="true"
            >
              {item.nr}
            </div>
            <div class="min-w-0">
              <h3 class="text-lg font-display font-bold text-brand-primary mb-3 leading-tight">{item.title}</h3>
              <p class="text-sm text-brand-ink/70 leading-relaxed font-light">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- SECTION 3: Wat wij doen — zes pijlers -->
  <section class="py-24 px-4 sm:px-6 bg-[#FFFAF4]" id="systeem">
    <div class="max-w-7xl mx-auto">

      <div class="max-w-2xl mb-16">
        <div class="label-pill">Onze aanpak</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
          Wat wij onder marketing<br /><span class="text-brand-accent">verstaan.</span>
        </h2>
        <p class="text-lg text-brand-ink/70 leading-relaxed font-light">
          Marketing is meer dan posts en ads. Het is een systeem waarbij elke pijler de andere versterkt — en waarbij AI het geheel versnelt en slimmer maakt. Wij werken aan zes lagen die samen structureel aanvragen genereren.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-brand-accent shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-5">
            Pijler 1
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">SEO & Vindbaarheid</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            Gevonden worden op de zoektermen die jouw ideale klant gebruikt — technisch, inhoudelijk en lokaal. Wij doen het zoekwoordonderzoek, repareren de technische basis en bouwen autoriteit op met content die rankt.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            AI helpt ons sneller patronen te zien in zoekgedrag en content te produceren die Google én jouw klant waardeert.
          </p>
        </div>

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-brand-primary shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-brand-primary/8 border border-brand-primary/15 rounded-full text-[10px] font-bold uppercase tracking-widest text-brand-primary mb-5">
            Pijler 2
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">Content & Autoriteit</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            Kennisartikelen, case studies en landingspagina's die niet alleen ranken maar ook overtuigen. Wij schrijven in jouw taal, voor jouw doelgroep — zodat een bezoeker weet waarom jij de juiste keuze bent.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            Consistente content bouwt vertrouwen op, lang voordat de klant de telefoon pakt.
          </p>
        </div>

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-brand-lime shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-brand-lime/20 border border-brand-lime/30 rounded-full text-[10px] font-bold uppercase tracking-widest text-[#6b7a0c] mb-5">
            Pijler 3
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">Social media & LinkedIn</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            Consistent aanwezig bij de beslissers die tellen — voor het bedrijf én de persoon erachter. Wij maken de posts, plannen de agenda en zorgen dat jouw bedrijf dagelijks zichtbaar is in de feeds van jouw doelgroep.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            LinkedIn is het sterkste B2B-kanaal. Wie er niet is, bestaat niet voor zijn volgende klant.
          </p>
        </div>

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-brand-accent/50 shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-brand-accent/8 border border-brand-accent/15 rounded-full text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-5">
            Pijler 4
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">E-mail & Nurturing</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            Leads die nu niet kopen, koelen niet af — als je het goed aanpakt. Wij bouwen geautomatiseerde e-mailreeksen die mensen warm houden totdat de timing klopt. Niemand wordt vergeten, alles wordt gemeten.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            Een goede e-mailstrategie verdubbelt de waarde van elke lead die je al hebt.
          </p>
        </div>

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-violet-400 shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-violet-50 border border-violet-200 rounded-full text-[10px] font-bold uppercase tracking-widest text-violet-600 mb-5">
            Pijler 5
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">AI & Automatisering</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            AI versnelt elk onderdeel van je marketing. Van zoekwoordonderzoek en contentproductie tot het scoren van leads en het automatisch opvolgen van aanvragen. Wij bouwen de AI-workflows die jouw systeem slimmer maken.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            Bedrijven die AI structureel inzetten in hun marketing groeien sneller — en doen het met minder manueel werk.
          </p>
        </div>

        <div class="bg-white rounded-[28px] p-8 lg:p-10 border-l-4 border-brand-primary/40 shadow-sm">
          <div class="inline-flex items-center px-3 py-1 bg-brand-primary/5 border border-brand-primary/10 rounded-full text-[10px] font-bold uppercase tracking-widest text-brand-primary/70 mb-5">
            Pijler 6
          </div>
          <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-primary mb-4">Betaalde Advertising</h3>
          <p class="text-base text-brand-ink/70 leading-relaxed font-light mb-3">
            Google Ads en LinkedIn-campagnes als versneller bovenop het organische systeem. Gericht op de juiste beslissers, met budget dat gaat naar wat aantoonbaar werkt — wekelijks bijgestuurd.
          </p>
          <p class="text-sm text-brand-ink/50 leading-relaxed font-light">
            Advertising werkt pas goed als de rest staat. Dan is het geen kostenpost, maar een groeihendel.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION 4: Het traject -->
  <section class="py-24 px-4 sm:px-6 bg-white">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-16">
        <div class="label-pill mx-auto">Het traject</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
          Van niets naar een systeem dat werkt.
        </h2>
        <p class="text-lg text-brand-ink/70 max-w-xl mx-auto leading-relaxed font-light">
          Wij bouwen niet eindeloos. Binnen 30 dagen staat het systeem. Dit is het traject dat wij met je doorlopen — van nulmeting tot structurele groei.
        </p>
      </div>

      <div class="relative">
        <div class="hidden lg:block absolute top-[52px] left-[calc(12.5%+32px)] right-[calc(12.5%+32px)] h-px bg-gradient-to-r from-amber-100 via-brand-accent/30 to-brand-primary/30 z-0"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 relative z-10">
          {[
            {
              stage: "1",
              label: "Week 1",
              title: "Analyse & strategie",
              desc: "We brengen in kaart hoe jouw marketing er nu voor staat — kanalen, content, concurrenten en kansen. We bouwen de strategie.",
              highlight: false,
              labelColor: "bg-amber-50 border-amber-200 text-amber-700",
            },
            {
              stage: "2",
              label: "Week 2–3",
              title: "Opbouw systeem",
              desc: "We bouwen de technische basis: SEO-structuur, contentagenda, social media planning, e-mailautomatisering en AI-workflows.",
              highlight: false,
              labelColor: "bg-orange-50 border-orange-200 text-orange-700",
            },
            {
              stage: "3",
              label: "Week 4",
              title: "Live & zichtbaar",
              desc: "Het systeem gaat live. Content wordt gepubliceerd, campagnes lopen, AI-automatisering staat aan. Jij ziet het direct.",
              highlight: false,
              labelColor: "bg-blue-50 border-blue-200 text-blue-700",
            },
            {
              stage: "4",
              label: "Doorlopend",
              title: "Groeien & optimaliseren",
              desc: "Wekelijkse bijsturing, maandelijks strategiegesprek. We draaien aan de knoppen totdat de aanvragen structureel binnenkomen.",
              highlight: true,
              labelColor: "bg-brand-accent/10 border-brand-accent/30 text-brand-accent",
            },
          ].map(s => (
            <div class={`flex flex-col items-center text-center p-6 rounded-[24px] ${s.highlight ? 'bg-brand-accent/5 border border-brand-accent/20' : 'bg-white border border-amber-50'}`}>
              <div class={`w-14 h-14 rounded-[18px] font-display font-black text-xl flex items-center justify-center mb-5 shadow-sm ${s.highlight ? 'bg-brand-accent text-white shadow-xl shadow-brand-accent/25 scale-110' : 'bg-white border-2 border-amber-100 text-brand-primary'}`}>
                {s.stage}
              </div>
              <span class={`inline-flex items-center px-3 py-1 rounded-full text-[9px] font-bold uppercase tracking-widest border mb-4 ${s.labelColor}`}>
                {s.label}
              </span>
              <h3 class={`text-base font-display font-bold mb-3 ${s.highlight ? 'text-brand-accent' : 'text-brand-primary'}`}>{s.title}</h3>
              <p class="text-sm text-brand-ink/70 leading-relaxed font-light">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            title: "Geen vijf bureaus. Één systeem.",
            desc: "Alles wordt gebouwd als één geheel. SEO voedt de content. Content leeft op LinkedIn. LinkedIn-bereik versterkt de advertenties. Advertenties brengen leads in het e-mailprogramma.",
          },
          {
            title: "AI als fundament, niet als gimmick.",
            desc: "We gebruiken AI om sneller te werken, slimmer te targeten en beter op te volgen. Niet als trucje, maar als structureel onderdeel van je marketingsysteem.",
          },
          {
            title: "Gebouwd voor de lange termijn.",
            desc: "Een goed systeem hoef je niet elk jaar opnieuw op te bouwen. Het fundament schaalt mee — en wordt elke maand sterker.",
          },
        ].map(item => (
          <div class="warm-card p-8">
            <div class="w-8 h-1 bg-brand-accent rounded-full mb-5"></div>
            <h3 class="text-base font-display font-bold text-brand-primary mb-3">{item.title}</h3>
            <p class="text-sm text-brand-ink/70 leading-relaxed font-light">{item.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- SECTION 5: Photo break -->
  <section class="relative overflow-hidden">
    <div class="h-48 sm:h-64 lg:h-[420px] w-full relative">
      <img
        src="/images/kantoor-1.webp"
        alt="Team Optimaal Groeien aan het werk"
        class="w-full h-full object-cover"
        loading="lazy"
        width="1440"
        height="420"
      />
      <div class="absolute inset-0 bg-brand-primary/55"></div>
      <div class="absolute inset-0 flex items-center justify-center px-4 sm:px-6">
        <div class="text-center max-w-2xl">
          <p class="text-xl sm:text-2xl lg:text-4xl font-display font-bold text-white leading-tight tracking-tight mb-5">
            "Niet meer bijhouden wie wat doet.<br />
            <span class="text-brand-lime">Wij zijn je marketingafdeling."</span>
          </p>
          <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-accent text-white rounded-2xl font-display font-bold transition-all hover:scale-[1.02] shadow-xl text-sm">
            Plan een gratis gesprek
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: Outro dark -->
  <section class="py-20 sm:py-24 px-4 sm:px-6 bg-brand-primary relative overflow-hidden" id="contact">
    <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-white/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[320px] h-[320px] rounded-full bg-brand-lime/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto relative z-10">
      <div class="flex flex-col lg:flex-row gap-16 items-start">

        <!-- Left: CTA block -->
        <div class="w-full lg:w-[58%] text-white">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-lime/20 border border-brand-lime/30 rounded-full text-[11px] uppercase tracking-widest font-bold text-brand-lime mb-8">
            Jouw marketing als sterkste groeimiddel
          </div>
          <h2 class="text-3xl lg:text-5xl font-display font-bold mb-6 leading-tight tracking-tight text-white">
            Marketing die samenwerkt.<br /><span class="text-brand-lime">Versneld door AI.</span>
          </h2>
          <p class="text-lg text-white/75 mb-10 leading-relaxed font-light max-w-lg">
            Je hebt geen vijf bureaus nodig. Je hebt een systeem nodig dat werkt — en een team dat het bewaakt en elke week scherper maakt. Dat zijn wij.
          </p>

          <div class="space-y-3 mb-10">
            {[
              {
                title: "Eén aanspreekpunt voor alles",
                sub: "Stefan staat voor je klaar. Geen keuzemenu's, geen doorverbinden naar juniors.",
              },
              {
                title: "Binnen 30 dagen draait het systeem",
                sub: "Geen eindeloze trajecten. Binnen een maand ben je zichtbaar bezig.",
              },
              {
                title: "Resultaat of gratis door",
                sub: "Na 6 maanden geen aantoonbare groei? Dan werken we gratis door totdat die er is.",
              },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 bg-white/5 border border-white/10 rounded-2xl">
                <svg class="w-5 h-5 text-brand-lime shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <div>
                  <div class="text-sm font-display font-bold text-white mb-0.5">{item.title}</div>
                  <div class="text-xs text-white/60 font-light leading-relaxed">{item.sub}</div>
                </div>
              </div>
            ))}
          </div>

          <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
            class="inline-flex items-center gap-2 px-10 py-5 bg-brand-accent text-white rounded-2xl font-display font-bold transition-all hover:scale-[1.02] shadow-xl shadow-brand-accent/20 text-base">
            Plan je gratis marketinganalyse
