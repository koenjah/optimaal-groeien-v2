---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="Onze expertise — Commerciële groei voor technische B2B-bedrijven | Optimaal Groeien"
  description="Optimaal Groeien is gespecialiseerd in commerciële groei voor technische B2B-bedrijven. Ontdek onze expertise, aanpak en de sectoren waar wij het verschil maken."
  canonical="https://optimaalgroeien.nl/oplossingen/onze-expertise"
>

  <!-- ─────────────────────────────────────────────
       HERO: two-column — text left, team photo right
       ───────────────────────────────────────────── -->
  <section class="hero-warm pt-36 pb-24 px-6 relative overflow-hidden">
    <!-- ambient glows -->
    <div class="absolute top-0 right-0 w-[520px] h-[520px] rounded-full bg-brand-accent/5 blur-[140px] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-1/4 w-[320px] h-[320px] rounded-full bg-amber-200/8 blur-[110px] pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">

        <!-- Left: text -->
        <div class="lg:w-[52%] text-center lg:text-left">
          <div class="label-pill lg:justify-start justify-center">
            <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
            Expertise in technische B2B
          </div>
          <h1 class="text-[2.2rem] sm:text-[2.8rem] lg:text-[3.4rem] font-display font-bold text-brand-primary leading-[1.08] tracking-tight mb-6">
            Wij kennen de wereld<br />
            <span class="text-brand-accent">van technische B2B</span><br />
            van binnen en buiten.
          </h1>
          <p class="text-lg text-brand-ink/70 leading-relaxed mb-5 max-w-xl mx-auto lg:mx-0">
            Expertise is geen lijst met diensten. Het is de diepte van kennis waarmee je beslissingen neemt die er écht toe doen. Die kennis hebben wij opgebouwd in de technische sector — en nergens anders.
          </p>
          <p class="text-base text-brand-ink/55 leading-relaxed mb-10 max-w-xl mx-auto lg:mx-0">
            Wij werken uitsluitend voor technische bedrijven. Niet omdat we moeten, maar omdat generieke marketing generieke resultaten geeft.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
            <a
              href="https://meetings-eu1.hubspot.com/stefan-kelderman"
              target="_blank"
              rel="noreferrer"
              class="btn-primary !py-4 !px-9 text-sm w-full sm:w-auto justify-center"
            >
              Vraag een gratis analyse aan
            </a>
            <a
              href="/oplossingen"
              class="w-full sm:w-auto px-7 py-4 bg-white text-brand-primary rounded-2xl font-display font-bold transition-all hover:scale-[1.02] border-2 border-amber-100 shadow-sm flex items-center justify-center gap-2 text-sm"
            >
              Bekijk onze oplossingen
            </a>
          </div>
        </div>

        <!-- Right: team photo -->
        <div class="lg:w-[48%] w-full">
          <div class="relative">
            <!-- glow halo -->
            <div class="absolute -inset-4 bg-gradient-to-br from-brand-accent/10 to-brand-primary/5 rounded-[40px] blur-2xl" aria-hidden="true"></div>
            <img
              src="/images/teamfoto-nieuw.webp"
              alt="Het team van Optimaal Groeien — specialisten in commerciële groei voor technische B2B-bedrijven"
              class="relative w-full rounded-[28px] shadow-2xl object-cover aspect-[4/3]"
              loading="eager"
            />
            <!-- floating badges — clamped so they never bleed on small screens -->
            <div class="absolute -bottom-4 left-4 sm:-bottom-5 sm:-left-5 bg-white rounded-2xl shadow-xl px-5 py-3 border border-amber-100">
              <div class="text-2xl font-display font-black text-brand-primary">8+</div>
              <div class="text-[11px] uppercase tracking-widest font-bold text-brand-ink/50">jaar in technische B2B</div>
            </div>
            <div class="absolute -top-4 right-4 sm:-top-5 sm:-right-5 bg-brand-accent rounded-2xl shadow-xl px-5 py-3">
              <div class="text-xl font-display font-black text-white">100%</div>
              <div class="text-[10px] uppercase tracking-widest font-bold text-white/80">focus op B2B techniek</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ─────────────────────────────────────────────
       4 EXPERTISE CARDS with ghost numbers 01–04
       ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-white">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-20 items-end mb-20">
        <div class="lg:w-1/2">
          <div class="label-pill">Diepgaande competenties</div>
          <h2 class="text-3xl lg:text-[2.8rem] font-display font-bold text-brand-primary leading-tight">
            Waar wij écht<br /><span class="text-brand-accent">goed in zijn.</span>
          </h2>
        </div>
        <div class="lg:w-1/2">
          <p class="text-lg text-brand-ink/65 leading-relaxed font-light">
            Expertise claimt iedereen. Wij laten het zien in specifieke kennis, een doordachte aanpak en aantoonbare resultaten. Dit zijn de vier gebieden waar onze competentie het diepst gaat.
          </p>
        </div>
      </div>

      <!-- Cards grid: 2-col desktop, 1-col mobile -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- 01 -->
        <div class="warm-card p-8 sm:p-10 relative overflow-hidden group">
          <!-- ghost number: overflow-hidden on parent clips it -->
          <div
            class="absolute -top-2 -right-3 font-display font-black leading-none select-none pointer-events-none text-brand-primary/4 group-hover:text-brand-accent/6 transition-colors duration-500"
            style="font-size: clamp(5rem, 14vw, 9rem);"
            aria-hidden="true"
          >01</div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-brand-primary mb-4 leading-snug">
              Commerciële groeisystemen bouwen voor technische bedrijven
            </h3>
            <p class="text-brand-ink/65 leading-relaxed font-light text-base mb-3">
              Een groeisysteem is geen campagne. Het is de gestructureerde verbinding tussen vindbaarheid, positionering, content en salesopvolging — gebouwd voor de lange termijn.
            </p>
            <p class="text-brand-ink/50 leading-relaxed font-light text-sm">
              Wij treden op als jouw commerciële afdeling, niet als extern bureau op afstand.
            </p>
          </div>
        </div>

        <!-- 02 -->
        <div class="warm-card p-8 sm:p-10 relative overflow-hidden group">
          <div
            class="absolute -top-2 -right-3 font-display font-black leading-none select-none pointer-events-none text-brand-primary/4 group-hover:text-brand-accent/6 transition-colors duration-500"
            style="font-size: clamp(5rem, 14vw, 9rem);"
            aria-hidden="true"
          >02</div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-brand-primary/8 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-brand-primary mb-4 leading-snug">
              B2B-sectoren die wij door en door kennen
            </h3>
            <p class="text-brand-ink/65 leading-relaxed font-light text-base mb-3">
              Techniek, industrie, installatie en advies — dit zijn onze sectoren. Wij begrijpen hoe besluitvorming hier werkt: lange trajecten, meerdere beslissers en hoge orderwaarden.
            </p>
            <p class="text-brand-ink/50 leading-relaxed font-light text-sm">
              Wij spreken de taal van jouw klant — ook als dat een inkoopmanager bij een machinebouwer is.
            </p>
          </div>
        </div>

        <!-- 03 -->
        <div class="warm-card p-8 sm:p-10 relative overflow-hidden group">
          <div
            class="absolute -top-2 -right-3 font-display font-black leading-none select-none pointer-events-none text-brand-primary/4 group-hover:text-brand-accent/6 transition-colors duration-500"
            style="font-size: clamp(5rem, 14vw, 9rem);"
            aria-hidden="true"
          >03</div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-brand-lime/20 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-brand-primary mb-4 leading-snug">
              Marketing en sales als één geheel laten werken
            </h3>
            <p class="text-brand-ink/65 leading-relaxed font-light text-base mb-3">
              Bij de meeste bedrijven zitten marketing en sales in aparte kokers. Wij bouwen het als één systeem: van het eerste zoekmoment tot het gesloten contract.
            </p>
            <p class="text-brand-ink/50 leading-relaxed font-light text-sm">
              Geen losse campagnes die niemand opvolgt. Eén lijn van aanvang tot opdracht.
            </p>
          </div>
        </div>

        <!-- 04 -->
        <div class="warm-card p-8 sm:p-10 relative overflow-hidden group">
          <div
            class="absolute -top-2 -right-3 font-display font-black leading-none select-none pointer-events-none text-brand-primary/4 group-hover:text-brand-accent/6 transition-colors duration-500"
            style="font-size: clamp(5rem, 14vw, 9rem);"
            aria-hidden="true"
          >04</div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-brand-primary mb-4 leading-snug">
              Resultaten die meetbaar zijn en standhouden
            </h3>
            <p class="text-brand-ink/65 leading-relaxed font-light text-base mb-3">
              Wij meten wat telt: aanvragen, offertes, omzet — niet paginaweergaven of likes. Elk kwartaal leggen wij verantwoording af over de cijfers die er voor jou toe doen.
            </p>
            <p class="text-brand-ink/50 leading-relaxed font-light text-sm">
              Wij denken in duurzame groei, niet in sprints die daarna stilvallen.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ─────────────────────────────────────────────
       TOOLSTACK: logo grid — wraps on mobile
       ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[#FFFAF4]">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-16">
        <div class="label-pill mx-auto">Toolstack en methoden</div>
        <h2 class="text-3xl lg:text-[2.8rem] font-display font-bold text-brand-primary mb-5">
          De tools die wij inzetten.
        </h2>
        <p class="text-lg text-brand-ink/60 max-w-xl mx-auto leading-relaxed font-light">
          Bewezen platforms, verbonden tot één werkend systeem. Geen tool om de tool — elke keuze is in dienst van jouw commerciële resultaat.
        </p>
      </div>

      <!-- 3-4 per row on mobile, 5 per row on desktop -->
      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-5 gap-4 sm:gap-5">
        {[
          { logo: "/images/logos/hubspot.svg",    name: "HubSpot",    role: "CRM & automation" },
          { logo: "/images/logos/google.svg",     name: "Google",     role: "SEO & Ads" },
          { logo: "/images/logos/linkedin.svg",   name: "LinkedIn",   role: "B2B social" },
          { logo: "/images/logos/make.svg",       name: "Make",       role: "Automatisering" },
          { logo: "/images/logos/claude.svg",     name: "Claude AI",  role: "AI content" },
          { logo: "/images/logos/gemini.svg",     name: "Gemini",     role: "Analyse & research" },
          { logo: "/images/logos/openai.svg",     name: "OpenAI",     role: "Taal & kennismodellen" },
          { logo: "/images/logos/salesforce.svg", name: "Salesforce", role: "Enterprise CRM" },
          { logo: "/images/logos/adobe.svg",      name: "Adobe",      role: "Visuele communicatie" },
          { logo: "/images/logos/brevo.svg",      name: "Brevo",      role: "E-mailmarketing" },
        ].map(tool => (
          <div class="bg-white rounded-[20px] border border-amber-100/80 p-5 flex flex-col items-center gap-3 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 text-center">
            <div class="h-9 flex items-center justify-center w-full">
              <img src={tool.logo} alt={tool.name} class="h-8 w-auto max-w-[70px] object-contain" loading="lazy" />
            </div>
            <div>
              <div class="text-xs font-bold text-brand-primary leading-tight">{tool.name}</div>
              <div class="text-[10px] text-brand-ink/50 leading-tight mt-0.5 font-medium">{tool.role}</div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ─────────────────────────────────────────────
       SECTOREN: pill cloud — wraps naturally
       ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-16 items-start lg:items-center">

        <!-- Left: text + CTA -->
        <div class="lg:w-[42%]">
          <div class="label-pill">Onze thuisbasis</div>
          <h2 class="text-3xl lg:text-[2.6rem] font-display font-bold text-brand-primary leading-tight mb-6">
            Bewezen in technische<br /><span class="text-brand-accent">B2B-sectoren.</span>
          </h2>
          <p class="text-base text-brand-ink/65 leading-relaxed font-light mb-8">
            Onze focus ligt bewust op technische B2B-bedrijven. Hieronder zie je de sectoren waar wij actief zijn en ervaring hebben opgebouwd.
          </p>
          <a
            href="https://meetings-eu1.hubspot.com/stefan-kelderman"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-brand-primary text-white rounded-2xl font-display font-bold transition-all hover:scale-[1.02] shadow-lg text-sm"
          >
            Bespreek jouw sector
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Right: pills — flex-wrap, no overflow -->
        <div class="lg:w-[58%] w-full">
          <div class="flex flex-wrap gap-2.5">
            {[
              { label: "Machinebouw",               active: true  },
              { label: "Installatietechniek",        active: true  },
              { label: "Ingenieursbureaus",          active: false },
              { label: "Maakindustrie",              active: true  },
              { label: "B2B Software",               active: false },
              { label: "Advies en consultancy",      active: false },
              { label: "Bouw en infra",              active: true  },
              { label: "Agrifood",                   active: false },
              { label: "Elektrotechniek",            active: true  },
              { label: "Procesautomatisering",       active: false },
              { label: "Industriële dienstverlening",active: true  },
              { label: "Meet- en regelapparatuur",   active: false },
              { label: "Cleantech en duurzaamheid",  active: false },
              { label: "Logistiek en supply chain",  active: false },
            ].map(sector => (
              <span
                class={`inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-display font-semibold text-sm transition-all ${
                  sector.active
                    ? 'bg-brand-primary text-white shadow-md'
                    : 'bg-[#FFFAF4] text-brand-primary border border-amber-100/80'
                }`}
              >
                {sector.active && <span class="w-1.5 h-1.5 bg-brand-accent rounded-full flex-shrink-0" aria-hidden="true"></span>}
                {sector.label}
              </span>
            ))}
          </div>
          <p class="text-xs text-brand-ink/40 mt-5 font-medium">
            Donker = actieve projecten. Overige sectoren op aanvraag.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ─────────────────────────────────────────────
       TEAM SECTION: images + people list
       ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[#FFFAF4]">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-16 items-center">

        <!-- Photo collage -->
        <div class="lg:w-[48%] w-full grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <img
              src="/images/stefan-teun.webp"
              alt="Stefan en Teun van Optimaal Groeien bespreken strategie voor een technische B2B-klant"
              class="w-full rounded-[24px] object-cover aspect-[16/9] shadow-xl"
              loading="lazy"
            />
          </div>
          <div>
            <img
              src="/images/kantoor-1.webp"
              alt="Werkplek Optimaal Groeien"
              class="w-full rounded-[20px] object-cover aspect-square shadow-lg"
              loading="lazy"
            />
          </div>
          <div>
            <img
              src="/images/actie-1.webp"
              alt="Team in actie bij Optimaal Groeien"
              class="w-full rounded-[20px] object-cover aspect-square shadow-lg"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Content -->
        <div class="lg:w-[52%]">
          <div class="label-pill">Het team achter de expertise</div>
          <h2 class="text-3xl lg:text-[2.6rem] font-display font-bold text-brand-primary leading-tight mb-6">
            Geen groot bureau.<br /><span class="text-brand-accent">Wel een scherp team.</span>
          </h2>
          <p class="text-base text-brand-ink/65 leading-relaxed font-light mb-5">
            Wij zijn een compact, gespecialiseerd team dat uitsluitend werkt voor technische B2B-bedrijven. Iedereen die aan jouw project werkt, begrijpt jouw sector — dit is onze hele wereld.
          </p>
          <p class="text-base text-brand-ink/55 leading-relaxed font-light mb-12">
            Stefan stuurt het commerciële traject persoonlijk aan. Geen junior die jouw dossier beheert — Stefan staat zelf voor je klaar.
          </p>

          <!-- Team members: 2-col grid, both mobile and desktop -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {[
              { name: "Stefan Kelderman", role: "Oprichter & Eigenaar",   initials: "SK", color: "bg-brand-accent/15 text-brand-accent" },
              { name: "Deniz Turan",     role: "Directeur",             initials: "DT", color: "bg-brand-primary/10 text-brand-primary" },
              { name: "Koen Duindam",    role: "SEO & AI",              initials: "KD", color: "bg-brand-lime/25 text-brand-primary" },
              { name: "Bram Bouwknegt",  role: "Online marketeer",      initials: "BB", color: "bg-brand-accent/10 text-brand-accent" },
            ].map(member => (
              <div class="flex items-center gap-3">
                <div class={`w-12 h-12 rounded-full flex items-center justify-center text-sm font-display font-bold flex-shrink-0 border border-white shadow-md ${member.color}`}>
                  {member.initials}
                </div>
                <div>
                  <div class="text-sm font-display font-bold text-brand-primary leading-tight">{member.name}</div>
                  <div class="text-[11px] text-brand-ink/50 font-medium leading-snug mt-0.5">{member.role}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ─────────────────────────────────────────────
       OUTRO: dark — headline + testimonials + CTA
       ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-brand-primary relative overflow-hidden" id="contact">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-white/4 blur-[140px] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-brand-lime/5 blur-[110px] pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto relative z-10">

      <!-- Headline -->
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-lime/20 border border-brand-lime/30 rounded-full text-[11px] uppercase tracking-widest font-bold text-brand-lime mb-8">
          Onze belofte
        </div>
        <h2 class="text-4xl lg:text-[3.4rem] font-display font-bold text-white leading-[1.1] tracking-tight mb-6">
          Expertise zonder resultaat<br /><span class="text-brand-lime">is niets waard.</span>
        </h2>
        <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed font-light">
          Wij bewijzen onze expertise niet in presentaties, maar in de groei van jouw bedrijf. Elk project meet zichzelf af aan aanvragen, omzet en duurzame marktpositie.
        </p>
      </div>

      <!-- 3-col: testimonial · CTA · testimonial — stacks to 1-col on mobile, CTA last -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">

        <!-- Testimonial 1 -->
