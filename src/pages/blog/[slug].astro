---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.ceil(words / 200);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sameCategory = allPosts.filter(p => p.data.slug !== post.data.slug && p.data.category === post.data.category);
const otherPosts = allPosts.filter(p => p.data.slug !== post.data.slug && p.data.category !== post.data.category);
const related = [...sameCategory, ...otherPosts].slice(0, 3);
---

<BlogLayout
  title={post.data.title + ' — Optimaal Groeien'}
  description={post.data.description}
  canonical={`https://optimaalgroeien.nl/blog/${post.data.slug}`}
  ogImage={post.data.heroImage}
  ogType="article"
  publishedTime={new Date(post.data.date).toISOString()}
  author={post.data.author}
>
  <!-- Hero — clean, readable -->
  <header class="bg-brand-primary pt-36 pb-10 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Meta row -->
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-brand-accent px-3 py-1 bg-brand-accent/15 rounded-full">
          {post.data.category}
        </span>
        <span class="text-[11px] text-white/35">
          {new Date(post.data.date).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
        <span class="text-[11px] text-white/35">{readingTime} min</span>
      </div>

      <!-- Title -->
      <h1 class="text-3xl lg:text-[2.6rem] font-display font-bold text-white leading-snug tracking-tight mb-4">
        {post.data.title}
      </h1>

      <!-- Description -->
      <p class="text-base lg:text-lg text-white/60 leading-relaxed mb-7 max-w-2xl">
        {post.data.description}
      </p>

      <!-- Author + stat inline -->
      <div class="flex items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <img
            src="/images/team-1-avatar.webp"
            alt={post.data.author}
            class="w-9 h-9 rounded-full object-cover object-[center_25%] border border-white/20"
            loading="eager"
          />
          <div>
            <p class="text-sm font-bold text-white leading-none mb-0.5">{post.data.author}</p>
            <p class="text-[11px] text-white/45">Oprichter Optimaal Groeien</p>
          </div>
        </div>
        {post.data.statHighlight && (
          <div class="text-right flex-shrink-0">
            <span class="text-2xl font-display font-black text-brand-accent leading-none">{post.data.statHighlight.value}</span>
            <p class="text-[10px] text-white/40 mt-0.5 max-w-[110px] leading-snug">{post.data.statHighlight.label}</p>
          </div>
        )}
      </div>
    </div>
  </header>

  {post.data.heroImage && (
    <div class="max-w-4xl mx-auto px-6 -mt-6 relative z-10">
      <img
        src={post.data.heroImage}
        alt={post.data.heroAlt || post.data.title}
        class="w-full rounded-[24px] shadow-2xl object-cover max-h-[480px]"
        loading="eager"
      />
    </div>
  )}

  <!-- Article body -->
  <article class="pt-10 pb-16 px-6 bg-[#FFFCF8]">
    <div class="max-w-3xl mx-auto">

      <!-- Key takeaways — light card, easy to skip -->
      {post.data.keyTakeaways && post.data.keyTakeaways.length > 0 && (
        <div class="mb-10 border border-amber-200/70 bg-white rounded-[16px] px-6 py-5">
          <p class="text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-3">Wat je meeneemt</p>
          <ul class="space-y-2.5">
            {post.data.keyTakeaways.map(point => (
              <li class="flex items-start gap-2.5">
                <span class="mt-[0.35rem] w-1.5 h-1.5 rounded-full bg-brand-accent flex-shrink-0"></span>
                <span class="text-[13px] text-brand-ink/70 leading-snug">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="article-body">
        <Content />
      </div>

      <!-- Tags -->
      <div class="mt-12 pt-8 border-t border-brand-soft flex flex-wrap gap-2">
        {post.data.tags.map(tag => (
          <span class="px-3 py-1 bg-white border border-brand-soft text-brand-ink/55 text-[12px] font-medium rounded-full">
            #{tag}
          </span>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-brand-primary rounded-[28px] p-8 lg:p-10 text-center">
        <h3 class="text-xl font-display font-bold text-white mb-3">
          Wil je dit toepassen in jouw bedrijf?
        </h3>
        <p class="text-white/65 mb-6 text-sm leading-relaxed">
          Plan een gratis analyse van 45 minuten. Stefan kijkt mee en geeft direct concrete aanbevelingen.
        </p>
        <a
          href="https://calendly.com/stefankelderman/15min"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-brand-accent text-white rounded-2xl font-display font-bold hover:bg-white hover:text-brand-accent transition-all duration-200"
        >
          Plan je gratis analyse →
        </a>
      </div>
    </div>
  </article>

  <!-- Related posts — always 3 -->
  <section class="py-16 px-6 bg-[#FFFAF4]">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8 gap-4">
        <h2 class="text-2xl font-display font-bold text-brand-primary">Lees ook</h2>
        <a href="/blog" class="text-[12px] font-bold text-brand-accent hover:underline flex-shrink-0">Alle artikelen →</a>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5">
        {related.map(p => (
          <a
            href={`/blog/${p.data.slug}`}
            class="group bg-white border border-amber-100/80 rounded-[20px] overflow-hidden hover:shadow-lg hover:shadow-amber-500/10 hover:-translate-y-1 transition-all duration-300 flex flex-col"
          >
            {p.data.heroImage && (
              <div class="aspect-[16/9] overflow-hidden">
                <img src={p.data.heroImage} alt={p.data.heroAlt || p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <span class="text-[9px] font-bold uppercase tracking-widest text-brand-accent mb-2 block">{p.data.category}</span>
              <h3 class="text-[14px] font-display font-bold text-brand-primary leading-snug mb-2 group-hover:text-brand-accent transition-colors flex-1">
                {p.data.title}
              </h3>
              <p class="text-[12px] text-brand-ink/50 leading-relaxed line-clamp-2 mb-3">{p.data.description}</p>
              <div class="text-[11px] font-bold text-brand-accent">
                Lees artikel <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BlogLayout>

<style is:global>
  /* ── Base article typography ── */
  .article-body h2 { font-size: 1.4rem; font-weight: 700; color: #053b63; margin-top: 3rem; margin-bottom: 0.875rem; font-family: var(--font-display); padding-bottom: 0.5rem; border-bottom: 2px solid #FEF3E8; }
  .article-body h3 { font-size: 1.1rem; font-weight: 700; color: #053b63; margin-top: 2rem; margin-bottom: 0.625rem; font-family: var(--font-display); }
  .article-body p  { color: rgba(51,65,85,0.82); line-height: 1.85; margin-bottom: 1.25rem; font-size: 1rem; }
  .article-body > p:first-of-type { font-size: 1.05rem; color: rgba(51,65,85,0.90); }
  .article-body ul { list-style: none; padding-left: 0; margin-bottom: 1.25rem; }
  .article-body ul li { color: rgba(51,65,85,0.82); margin-bottom: 0.55rem; line-height: 1.75; padding-left: 1.5rem; position: relative; }
  .article-body ul li::before { content: ''; position: absolute; left: 0; top: 0.65em; width: 6px; height: 6px; border-radius: 50%; background: #f17a29; }
  .article-body ol { list-style: none; padding-left: 0; margin-bottom: 1.25rem; counter-reset: ol-counter; }
  .article-body ol li { color: rgba(51,65,85,0.82); margin-bottom: 0.55rem; line-height: 1.75; padding-left: 2rem; position: relative; counter-increment: ol-counter; }
  .article-body ol li::before { content: counter(ol-counter); position: absolute; left: 0; top: 0.1em; width: 1.35rem; height: 1.35rem; border-radius: 50%; background: #053b63; color: white; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .article-body strong { font-weight: 700; color: #053b63; }
  .article-body a { color: #f17a29; text-decoration: none; border-bottom: 1px solid #f17a2940; transition: border-color 0.15s; }
  .article-body a:hover { border-bottom-color: #f17a29; }
  .article-body hr { border: none; border-top: 2px solid #F1F5F9; margin: 2.5rem 0; }
  .article-body blockquote { border-left: 3px solid #f17a29; padding: 0.75rem 1.25rem; background: #fffaf4; border-radius: 0 14px 14px 0; margin: 1.75rem 0; }
  .article-body blockquote p { margin-bottom: 0; color: #053b63; font-style: italic; }
  .article-body table { width: 100%; border-collapse: collapse; margin-bottom: 1.75rem; font-size: 0.88rem; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 3px rgba(5,59,99,0.08); }
  .article-body th { background: #053b63; color: white; padding: 0.875rem 1rem; text-align: left; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.03em; }
  .article-body td { padding: 0.75rem 1rem; border-bottom: 1px solid #F1F5F9; color: rgba(51,65,85,0.82); }
  .article-body tr:last-child td { border-bottom: none; }
  .article-body tr:nth-child(even) td { background: #FAFBFC; }

  /* ── Custom in-article elements (for subagent use) ── */

  /* Pull quote — for embedding in article body */
  .citaat { border-left: 3px solid #f17a29; padding: 0.875rem 1.25rem; background: #fffaf4; border-radius: 0 16px 16px 0; margin: 2rem 0; }
  .citaat p, .citaat { color: #053b63; font-style: italic; font-size: 1.05rem; line-height: 1.7; margin-bottom: 0; font-weight: 600; }

  /* Callout / tip box — orange accent */
  .tip { background: #FFF8F2; border: 1px solid #FAE0C8; border-left: 3px solid #f17a29; border-radius: 0 14px 14px 0; padding: 1rem 1.25rem; margin: 2rem 0; }
  .tip-label { display: block; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #f17a29; margin-bottom: 0.4rem; }
  .tip p { color: rgba(51,65,85,0.85); margin-bottom: 0; line-height: 1.7; font-size: 0.95rem; }

  /* Insight card — blue tint, subtle shadow */
  .inzicht { background: white; border: 1px solid #E4EEF8; border-radius: 16px; padding: 1.25rem 1.5rem; margin: 2rem 0; box-shadow: 0 2px 12px rgba(5,59,99,0.06); }
  .inzicht-label { display: block; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #053b63; margin-bottom: 0.5rem; }
  .inzicht p { color: rgba(51,65,85,0.85); margin-bottom: 0; line-height: 1.7; font-size: 0.95rem; }

  /* Numbered steps — custom visual list */
  .stappen { margin: 2rem 0; display: flex; flex-direction: column; gap: 1rem; }
  .stap { display: flex; gap: 1rem; align-items: flex-start; }
  .stap-nr { width: 2rem; height: 2rem; background: #053b63; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; margin-top: 0.1rem; }
  .stap-tekst { flex: 1; color: rgba(51,65,85,0.82); line-height: 1.75; padding-top: 0.25rem; }
  .stap-tekst strong { color: #053b63; }

  /* Big number highlight — inline stat emphasis */
  .getal { display: flex; align-items: baseline; gap: 0.75rem; margin: 2rem 0; padding: 1.25rem 1.5rem; background: #053b63; border-radius: 16px; }
  .getal-waarde { font-size: 2.5rem; font-weight: 900; color: #f17a29; line-height: 1; font-family: var(--font-display); }
  .getal-label { color: rgba(255,255,255,0.65); font-size: 0.875rem; line-height: 1.5; max-width: 220px; }

  /* Checklist — branded checkbox list */
  .checklist { list-style: none; padding: 0; margin: 1.5rem 0; }
  .checklist li { display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 0.6rem; color: rgba(51,65,85,0.82); line-height: 1.7; font-size: 0.95rem; padding-left: 0 !important; }
  .checklist li::before { display: none !important; }
  .checklist li::after { content: none; }
  .check { width: 1.1rem; height: 1.1rem; border-radius: 4px; background: #f17a29; flex-shrink: 0; margin-top: 0.25rem; display: flex; align-items: center; justify-content: center; }
  .check::after { content: '✓'; color: white; font-size: 0.6rem; font-weight: 900; }

  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
