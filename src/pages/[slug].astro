---
import EmdashContentPage from '../components/EmdashContentPage.astro';
import { getCmsEntry } from '../lib/emdash-content';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const entry = slug ? await getCmsEntry('pages', slug) : null;

if (!entry) {
  return Astro.redirect('/404');
}
---

<EmdashContentPage entry={entry} type="page" slug={slug} />
