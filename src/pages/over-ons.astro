---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="Over ons — Het team achter Optimaal Groeien | Commercieel Partner B2B"
  description="Wij zijn Optimaal Groeien. Geen bureau met een propositie, maar een team dat écht meewerkt. Leer het team kennen dat de commerciële groei van B2B-bedrijven in de technische sector runt."
  canonical="https://optimaalgroeien.nl/over-ons"
  ogImage="https://optimaalgroeien.nl/images/teamfoto-nieuw.webp"
>

  <!-- ═══ HERO ═══ -->
  <section class="hero-warm pt-36 pb-0 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-brand-accent/5 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 items-end">

        <!-- Tekst -->
        <div class="lg:w-[45%] pb-12 lg:pb-20">
          <div class="label-pill">
            <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
            Over ons
          </div>
          <h1 class="text-[2.4rem] lg:text-[3.2rem] font-display font-bold text-brand-primary leading-[1.1] tracking-tight mb-6">
            Geen bureau.<br />
            <span class="text-brand-accent">Jouw commerciële afdeling.</span>
          </h1>
          <p class="text-lg text-brand-ink/70 leading-relaxed mb-8 font-light max-w-lg">
            We zijn een team van specialisten dat B2B-bedrijven in de technische sector helpt om structureel te groeien. Niet met losse campagnes — maar door echt mee te werken aan de commerciële machine van jouw bedrijf.
          </p>
          <div class="flex flex-wrap gap-4 text-[11px] font-bold uppercase tracking-widest text-brand-primary/50">
            <span>Opgericht 2018</span>
            <span class="text-brand-accent">·</span>
            <span>Raalte, Nederland</span>
            <span class="text-brand-accent">·</span>
            <span>10 specialisten</span>
          </div>
        </div>

        <!-- Foto — loopt tot rand, stapelt op mobile -->
        <div class="lg:w-[55%] w-full">
          <div class="rounded-t-[32px] overflow-hidden shadow-2xl">
            <img
              src="/images/teamfoto-nieuw.webp"
              alt="Het team van Optimaal Groeien"
              class="w-full h-[340px] sm:h-[420px] lg:h-[520px] object-cover object-top"
              loading="eager"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ CIJFERS ═══ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">

      <div class="grid sm:grid-cols-3 gap-6 mb-20">
        <div class="warm-card p-10 flex flex-col gap-4">
          <div class="text-5xl font-display font-black text-brand-accent">8+</div>
          <div class="text-lg font-display font-bold text-brand-primary">Jaar ervaring</div>
          <p class="text-sm text-brand-ink/70 font-light leading-relaxed">We werken al jaren met B2B-bedrijven in industrie, logistiek, bouw en techniek. We kennen de sector van binnen en buiten.</p>
        </div>
        <div class="warm-card p-10 flex flex-col gap-4">
          <div class="text-5xl font-display font-black text-brand-accent">100+</div>
          <div class="text-lg font-display font-bold text-brand-primary">Bedrijven geholpen</div>
          <p class="text-sm text-brand-ink/70 font-light leading-relaxed">Van scale-ups tot gevestigde namen in de maakindustrie. We weten wat werkt — en wat niet.</p>
        </div>
        <div class="warm-card p-10 flex flex-col gap-4">
          <div class="text-5xl font-display font-black text-brand-accent">150%</div>
          <div class="text-lg font-display font-bold text-brand-primary">Gemiddelde groei</div>
          <p class="text-sm text-brand-ink/70 font-light leading-relaxed">Onze klanten groeien gemiddeld 150% in organisch bereik na 6 maanden samenwerking. Geen toeval — een systeem.</p>
        </div>
      </div>

      <!-- Sfeerfotos grid -->
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="rounded-[24px] overflow-hidden col-span-2 lg:col-span-1">
          <img src="/images/kantoor-1.webp" alt="Optimaal Groeien aan het werk" class="w-full h-[240px] lg:h-full lg:min-h-[424px] object-cover" loading="lazy" />
        </div>
        <div class="rounded-[24px] overflow-hidden">
          <img src="/images/actie-1.webp" alt="Team meeting" class="w-full h-[200px] object-cover" loading="lazy" />
        </div>
        <div class="rounded-[24px] overflow-hidden">
          <img src="/images/actie-2.webp" alt="Samenwerken" class="w-full h-[200px] object-cover" loading="lazy" />
        </div>
        <div class="rounded-[24px] overflow-hidden">
          <img src="/images/kantoor-2.webp" alt="Kantoor Raalte" class="w-full h-[200px] object-cover" loading="lazy" />
        </div>
        <div class="rounded-[24px] overflow-hidden">
          <img src="/images/actie-3.webp" alt="Strategie sessie" class="w-full h-[200px] object-cover" loading="lazy" />
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ MISSIE ═══ -->
  <section class="py-24 px-6 bg-[#FFFAF4]">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">

      <div class="lg:w-[48%] w-full">
        <div class="rounded-[28px] overflow-hidden shadow-xl">
          <img
            src="/images/stefan-teun.webp"
            alt="Stefan Kelderman en collega"
            class="w-full h-[380px] lg:h-[500px] object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>

      <div class="lg:w-[52%]">
        <div class="label-pill">Waarom we dit doen</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-6">
          Technische bedrijven verdienen<br /><span class="text-brand-accent">betere commercie.</span>
        </h2>
        <p class="text-lg text-brand-ink/70 leading-relaxed font-light mb-5">
          De meeste B2B-bedrijven in de industrie doen geweldig werk. Hun producten zijn top, hun klanten zijn blij — maar nieuwe klanten vinden gaat op gevoel en toeval.
        </p>
        <p class="text-brand-ink/70 leading-relaxed font-light mb-5">
          Wij geloven dat technisch vakmanschap zichtbaar mag zijn. Een bedrijf dat 40 jaar lang kwaliteit levert, mag dat uitstralen — online, op LinkedIn, in de inbox van de inkoper die eigenlijk al had moeten bellen.
        </p>
        <p class="text-brand-ink/70 leading-relaxed font-light mb-10">
          Daarom zijn we Optimaal Groeien. Geen bureau op afstand — een team dat naast je staat en ook de mouwen opstroopt.
        </p>
        <div class="flex items-center gap-4">
          <img src="/images/team-stefan.webp" class="w-12 h-12 rounded-full object-cover object-[center_25%] border-2 border-white shadow" alt="Stefan Kelderman" loading="lazy" />
          <div>
            <div class="font-display font-bold text-brand-primary">Stefan Kelderman</div>
            <div class="text-xs text-brand-ink/60 uppercase tracking-widest font-bold">Oprichter</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ HET TEAM ═══ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">

      <!-- Intro -->
      <div class="flex flex-col lg:flex-row gap-12 items-end mb-16">
        <div class="lg:w-1/2">
          <div class="label-pill">Het team</div>
          <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary">
            De mensen die<br /><span class="text-brand-accent">voor je aan de slag gaan.</span>
          </h2>
        </div>
        <div class="lg:w-1/2">
          <p class="text-lg text-brand-ink/70 font-light leading-relaxed">
            Geen anoniem bureau. Geen keuzemenu's. Gewoon mensen die goed zijn in hun vak en écht betrokken zijn bij de bedrijven waarmee ze werken.
          </p>
        </div>
      </div>

      <!-- Grid: Stefan dubbel, rest 4-koloms -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

        <!-- Stefan -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img
              src="/images/team-stefan.webp"
              alt="Stefan Kelderman"
              class="w-full h-full object-cover object-[center_top] group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Stefan Kelderman</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Oprichter & Eigenaar</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Trekt de strategie, heeft de kortste lijntjes en is het geweten van elk commercieel besluit dat wij maken.</p>
            <a href="https://www.linkedin.com/in/stefan-kelderman-28b4b6168/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Deniz -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-deniz.webp" alt="Deniz Turan" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Deniz Turan</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Directeur</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Houdt de organisatie scherp. Zorgt dat strategie ook daadwerkelijk uitgevoerd wordt.</p>
            <a href="https://www.linkedin.com/in/deniz-t-aa152315a/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Brian -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-brian.webp" alt="Brian Bandel" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Brian Bandel</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Accountmanager</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Eerste aanspreekpunt voor klanten. Verbindt de wensen van het bedrijf aan het werk van het team.</p>
            <a href="https://www.linkedin.com/in/brianbandel/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Tanja -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-tanja.webp" alt="Tanja Avedisian" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Tanja Avedisian</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Branding specialist</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Zorgt dat jouw bedrijf eruitziet zoals het voelt van binnen. Sterk, onderscheidend en herkenbaar.</p>
            <a href="https://nl.linkedin.com/in/tanja-avedisian-5456b1190" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Jorieke -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-jorieke.webp" alt="Jorieke Bronsvoort" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Jorieke Bronsvoort</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Branding specialist</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Van logo tot campagnebeelden. Maakt visuele communicatie die blijft hangen.</p>
            <a href="https://www.linkedin.com/in/jorieke-bronsvoort-348633130/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Koen -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-koen.webp" alt="Koen Duindam" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Koen Duindam</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">SEO & AI</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">15 jaar SEO-ervaring, 4 jaar AI-zoekoptimalisatie. Zorgt dat jij zichtbaar bent in Google én in ChatGPT.</p>
            <a href="https://www.linkedin.com/in/koen-duindam/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- Bram -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-bram.webp" alt="Bram Bouwknegt" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Bram Bouwknegt</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Online marketeer</div>
            <p class="text-xs text-brand-ink/70 font-light leading-relaxed mb-3">Bouwt campagnes die clicks omzetten in leads. Pragmatisch, snel en resultaatgericht.</p>
            <a href="https://www.linkedin.com/in/bram-bouwknegt-6074b0269" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-brand-ink/30 hover:text-[#0A66C2] transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
            </a>
          </div>
        </div>


        <!-- Evi -->
        <div class="warm-card overflow-hidden group">
          <div class="overflow-hidden h-52">
            <img src="/images/team-evi.webp" alt="Evi-Pluis Bentum" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="p-5 bg-white">
            <div class="font-display font-bold text-sm text-brand-primary mb-0.5">Evi-Pluis Bentum</div>
            <div class="text-[10px] uppercase tracking-widest text-brand-accent font-bold mb-3">Marketing communicatie</div>
