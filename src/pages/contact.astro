---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="Contact — Maak kennis met Optimaal Groeien | Stefan Kelderman"
  description="Plan een vrijblijvend gesprek met Stefan Kelderman. 15 minuten kennismaken, geen pitch, geen verplichtingen."
  canonical="https://optimaalgroeien.nl/contact"
>

  <!-- ═══ HERO: full-bleed split ═══ -->
  <section class="flex flex-col lg:flex-row lg:min-h-screen">

    <!-- Foto: links, rand tot rand, vol scherm hoog -->
    <div class="w-full h-[52vw] max-h-[480px] lg:max-h-none lg:h-auto lg:w-[44%] lg:min-h-screen relative overflow-hidden shrink-0">
      <img
        src="/images/team-stefan-relax-lg.webp"
        alt="Stefan Kelderman — oprichter Optimaal Groeien"
        class="w-full h-full object-cover object-[center_12%]"
        loading="eager"
      />
      <!-- Subtiele vignette aan onderkant op mobile -->
      <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-[#FFFAF4] to-transparent lg:hidden pointer-events-none"></div>
    </div>

    <!-- Tekst + contact: rechts, warm achtergrond -->
    <div class="lg:w-[56%] bg-[#FFFAF4] flex items-center lg:items-center">
      <div class="w-full px-8 lg:px-16 xl:px-24 py-14 lg:py-0 lg:pt-36 lg:pb-24 max-w-xl lg:max-w-none">

        <div class="label-pill mb-8">
          <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
          Neem contact op
        </div>

        <h1 class="text-[2.6rem] lg:text-[3.4rem] xl:text-[4rem] font-display font-bold text-brand-primary leading-[1.06] tracking-tight mb-6">
          Laten we kennis<br />
          <span class="text-brand-accent">maken.</span>
        </h1>

        <p class="text-lg text-brand-ink/65 leading-relaxed mb-8 font-light max-w-md">
          Laat kort je gegevens achter. Stefan of iemand uit het team komt snel bij je terug.
        </p>

        <form
          id="contact-form"
          data-contact-form
          class="bg-white/80 border border-amber-100/90 rounded-[24px] p-5 sm:p-6 shadow-sm mb-8"
        >
          <div class="hidden" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="block text-xs font-bold uppercase tracking-widest text-brand-primary/70 mb-2">Naam</label>
              <input id="contact-name" name="name" type="text" required autocomplete="name" class="w-full px-4 py-3 rounded-2xl border border-amber-100 bg-white text-brand-ink placeholder:text-brand-ink/35 outline-none transition focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/10" />
            </div>
            <div>
              <label for="contact-company" class="block text-xs font-bold uppercase tracking-widest text-brand-primary/70 mb-2">Bedrijf</label>
              <input id="contact-company" name="company" type="text" required autocomplete="organization" class="w-full px-4 py-3 rounded-2xl border border-amber-100 bg-white text-brand-ink placeholder:text-brand-ink/35 outline-none transition focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/10" />
            </div>
            <div>
              <label for="contact-email" class="block text-xs font-bold uppercase tracking-widest text-brand-primary/70 mb-2">E-mail</label>
              <input id="contact-email" name="email" type="email" required autocomplete="email" class="w-full px-4 py-3 rounded-2xl border border-amber-100 bg-white text-brand-ink placeholder:text-brand-ink/35 outline-none transition focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/10" />
            </div>
            <div>
              <label for="contact-phone" class="block text-xs font-bold uppercase tracking-widest text-brand-primary/70 mb-2">Telefoon</label>
              <input id="contact-phone" name="phone" type="tel" autocomplete="tel" class="w-full px-4 py-3 rounded-2xl border border-amber-100 bg-white text-brand-ink placeholder:text-brand-ink/35 outline-none transition focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/10" />
            </div>
          </div>

          <div class="mt-4">
            <label for="contact-message" class="block text-xs font-bold uppercase tracking-widest text-brand-primary/70 mb-2">Waar kunnen we mee helpen?</label>
            <textarea id="contact-message" name="message" required rows="4" class="w-full px-4 py-3 rounded-2xl border border-amber-100 bg-white text-brand-ink placeholder:text-brand-ink/35 outline-none transition resize-none leading-relaxed focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/10"></textarea>
          </div>

          <div class="mt-5 flex flex-col sm:flex-row sm:items-center gap-3">
            <button
              type="submit"
              class="group inline-flex items-center justify-center gap-3 px-7 py-4 bg-brand-primary text-white rounded-2xl font-display font-bold text-base transition-all hover:bg-brand-accent hover:scale-[1.02] shadow-lg shadow-brand-primary/15 disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:scale-100"
            >
              Verstuur aanvraag
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <p data-contact-status class="text-sm text-brand-ink/60 min-h-[1.5rem]" aria-live="polite"></p>
          </div>
        </form>

        <!-- Secundaire opties -->
        <div class="flex flex-col gap-3 pt-6 border-t border-amber-200/60 mb-12">
          <a
            href="https://meetings-eu1.hubspot.com/stefan-kelderman"
            target="_blank"
            rel="noreferrer"
            data-leadinfo-url="/contact-plan-gesprek"
            class="group flex items-center gap-3 text-brand-ink/60 hover:text-brand-primary transition-colors text-sm font-medium"
          >
            <svg class="w-4 h-4 text-brand-accent/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M8 7V3M16 7V3M4 11h16M5 5h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg>
            Plan direct een gesprek
          </a>
          <a href="mailto:marketing@optimaalgroeien.nl" data-leadinfo-url="/contact-email-click" class="group flex items-center gap-3 text-brand-ink/60 hover:text-brand-primary transition-colors text-sm font-medium">
            <svg class="w-4 h-4 text-brand-accent/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            marketing@optimaalgroeien.nl
          </a>
          <a href="tel:+31572700246" data-leadinfo-url="/contact-phone-click" class="group flex items-center gap-3 text-brand-ink/60 hover:text-brand-primary transition-colors text-sm font-medium">
            <svg class="w-4 h-4 text-brand-accent/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.9 12.45 19.79 19.79 0 0 1 1.97 3.92 2 2 0 0 1 3.95 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +31 57 270 02 46
          </a>
          <div class="flex items-center gap-3 text-brand-ink/40 text-sm">
            <svg class="w-4 h-4 text-brand-accent/50 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Boeierstraat 9, Raalte
          </div>
        </div>

        <!-- Stefan handtekening -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 border border-amber-200">
            <img src="/images/team-stefan.webp" alt="Stefan Kelderman" class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
          <div>
            <div class="font-display font-bold text-brand-primary text-sm">Stefan Kelderman</div>
            <div class="text-xs text-brand-ink/40 font-medium">Oprichter · max 4 kennismakingen per maand</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ PERSOONLIJKE NOOT ═══ -->
  <section class="py-28 px-6 bg-white">
    <div class="max-w-2xl mx-auto">

      <p class="text-[1.65rem] lg:text-[2rem] font-display font-bold text-brand-primary leading-[1.3] mb-8">
        "Ik spreek liever met je dan dat ik je een offerte mail."
      </p>

      <p class="text-brand-ink/60 leading-relaxed mb-4 font-light text-lg">
        Een kwartier praten vertelt mij meer dan vijf pagina's intake. Als er een klik is, weet je dat snel.
      </p>
      <p class="text-brand-ink/60 leading-relaxed mb-10 font-light text-lg">
        Geen klik? Dan zeg ik dat ook gewoon. Geen moeite gedaan, geen tijd verspild.
      </p>

      <a
        href="https://meetings-eu1.hubspot.com/stefan-kelderman"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-accent text-white rounded-2xl font-display font-bold text-sm transition-all hover:scale-[1.02] shadow-md shadow-brand-accent/20"
      >
        Plan een vrijblijvend gesprek
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="py-28 px-6 bg-[#FFFAF4]">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-16 items-start">

        <div class="lg:w-[36%] lg:sticky lg:top-32">
          <div class="label-pill">Veelgestelde vragen</div>
          <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
            Wat mensen<br /><span class="text-brand-accent">ons vragen.</span>
          </h2>
          <p class="text-brand-ink/50 leading-relaxed font-light">Eerlijke vragen, eerlijke antwoorden.</p>
        </div>

        <div class="lg:w-[64%] w-full space-y-3">

          <details class="group bg-white border border-amber-100/80 rounded-[24px] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-display font-semibold text-brand-primary text-base hover:text-brand-accent transition-colors select-none">
              Is Optimaal Groeien geschikt voor mijn bedrijf?
              <span class="w-8 h-8 rounded-full bg-amber-50 border border-amber-100 flex items-center justify-center shrink-0 transition-transform duration-200 group-open:rotate-45">
                <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-brand-ink/60 text-sm leading-relaxed border-t border-amber-50">
              We werken met technische B2B-bedrijven: machinebouwers, installateurs, ingenieursbureaus en toeleveranciers. Lange verkoopcyclus, complexe offertes of moeite met nieuwe klanten aantrekken? Dan past onze aanpak waarschijnlijk goed.
            </div>
          </details>

          <details class="group bg-white border border-amber-100/80 rounded-[24px] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-display font-semibold text-brand-primary text-base hover:text-brand-accent transition-colors select-none">
              Wat kost samenwerking?
              <span class="w-8 h-8 rounded-full bg-amber-50 border border-amber-100 flex items-center justify-center shrink-0 transition-transform duration-200 group-open:rotate-45">
                <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-brand-ink/60 text-sm leading-relaxed border-t border-amber-50">
              We werken niet met standaard tariefkaarten. Na een kennismaking maken we een voorstel op maat — afgestemd op jouw situatie. Geen verrassingen achteraf.
            </div>
          </details>

          <details class="group bg-white border border-amber-100/80 rounded-[24px] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-display font-semibold text-brand-primary text-base hover:text-brand-accent transition-colors select-none">
              Hoe snel kunnen we starten?
              <span class="w-8 h-8 rounded-full bg-amber-50 border border-amber-100 flex items-center justify-center shrink-0 transition-transform duration-200 group-open:rotate-45">
                <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-brand-ink/60 text-sm leading-relaxed border-t border-amber-50">
              Zodra er een klik is en het voorstel staat, kunnen we binnen een tot twee weken starten. Als jij klaar bent, zijn wij dat ook.
            </div>
          </details>

          <details class="group bg-white border border-amber-100/80 rounded-[24px] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-display font-semibold text-brand-primary text-base hover:text-brand-accent transition-colors select-none">
              Wat als ik nu nog niet klaar ben?
              <span class="w-8 h-8 rounded-full bg-amber-50 border border-amber-100 flex items-center justify-center shrink-0 transition-transform duration-200 group-open:rotate-45">
                <svg class="w-4 h-4 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-brand-ink/60 text-sm leading-relaxed border-t border-amber-50">
              Geen enkel probleem. Een gesprek is vrijblijvend en verplicht je tot niets. Je gaat er altijd iets aan hebben — ook als we uiteindelijk niet samenwerken.
            </div>
          </details>

        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const contactForm = document.querySelector('[data-contact-form]');
    const contactStatus = document.querySelector('[data-contact-status]');

    function trackLeadinfoPage(path) {
      try {
        if (typeof window.leadinfo === 'function') {
          window.leadinfo('setCustomUrl', path);
          window.leadinfo('trackPageView');
        }
      } catch (_) {
        // Tracking should never block the conversion path.
      }
    }

    document.querySelectorAll('[data-leadinfo-url]').forEach((link) => {
      link.addEventListener('click', () => {
        const path = link.getAttribute('data-leadinfo-url');
        if (path) trackLeadinfoPage(path);
      });
    });

    if (contactForm && contactStatus) {
      const submitButton = contactForm.querySelector('button[type="submit"]');
      const defaultButtonText = submitButton ? submitButton.innerHTML : '';

      contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!contactForm.reportValidity()) return;

        const formData = new FormData(contactForm);
        const payload = Object.fromEntries(formData.entries());
        payload.pageUrl = window.location.href;
        payload.source = 'contactpagina';

        contactStatus.textContent = 'Versturen...';
        contactStatus.className = 'text-sm text-brand-ink/60 min-h-[1.5rem]';
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.innerHTML = 'Versturen...';
        }

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await response.json().catch(() => ({}));

          if (!response.ok || !data.success) {
            throw new Error(data.error || 'Submit failed');
          }

          trackLeadinfoPage('/contactformulier-ingediend');
          contactForm.reset();
          contactStatus.textContent = 'Dank je. We nemen snel contact met je op.';
          contactStatus.className = 'text-sm text-emerald-700 min-h-[1.5rem] font-medium';
        } catch (_) {
          contactStatus.innerHTML =
            'Versturen lukt niet. Mail direct naar <a class="underline font-semibold" href="mailto:marketing@optimaalgroeien.nl">marketing@optimaalgroeien.nl</a>.';
          contactStatus.className = 'text-sm text-red-700 min-h-[1.5rem] font-medium';
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.innerHTML = defaultButtonText;
          }
        }
      });
    }
  </script>

</ServiceLayout>
