---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="LinkedIn voor B2B — Thought Leadership die beslissers bereikt | Optimaal Groeien"
  description="Voor B2B-bedrijven in de technische sector is LinkedIn het meest effectieve kanaal om beslissers te bereiken. Wij bouwen jouw LinkedIn-autoriteit — consistent, met jouw stem, als onderdeel van een compleet commercieel systeem."
  canonical="https://optimaalgroeien.nl/social-media"
>

  <!-- Hero -->
  <section class="hero-warm pt-36 pb-24 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[420px] h-[420px] rounded-full bg-brand-accent/5 blur-[140px] pointer-events-none"></div>
    <div class="max-w-7xl mx-auto relative z-10">
      <div class="max-w-3xl">
        <div class="label-pill">
          <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
          LinkedIn voor B2B
        </div>
        <h1 class="text-[2.4rem] lg:text-[3.25rem] font-display font-bold text-brand-primary leading-[1.1] tracking-tight mb-6">
          LinkedIn als autoriteit.<br />
          <span class="text-brand-accent">Zo bereik je de beslisser.</span>
        </h1>
        <p class="text-lg text-brand-ink/70 max-w-2xl leading-relaxed mb-10">
          Inkopers en directeuren evalueren leveranciers eerst op LinkedIn — voordat ze bellen. Wij bouwen de aanwezigheid waardoor jij als vanzelfsprekende keuze naar voren komt.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
            class="btn-primary !py-4 !px-9 text-sm w-full sm:w-auto justify-center">
            Plan een gratis gesprek
          </a>
          <a href="/#cases"
            class="w-full sm:w-auto px-7 py-4 bg-white text-brand-primary rounded-2xl font-display font-bold transition-all hover:scale-[1.02] border-2 border-amber-100 shadow-sm flex items-center justify-center gap-2 text-sm">
            Bekijk klantverhalen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Herkenbaar — pijnpunten -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl mb-14">
        <div class="label-pill">Herkenbaar?</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
          Wel aanwezig op LinkedIn.<br />
          <span class="text-brand-accent">Maar niet zichtbaar.</span>
        </h2>
        <p class="text-lg text-brand-ink/70 leading-relaxed font-light">
          De meeste technische bedrijven zijn actief op LinkedIn. Maar zonder strategie levert het niets op.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            label: "Inconsistente posting",
            desc: "Een maand actief, dan drie weken stil. Algoritme straft het, beslissers merken het."
          },
          {
            label: "Geen strategie",
            desc: "Posts zonder doel — bedrijfsnieuwtjes en gefeliciteerd-berichten die niemand lezen wil."
          },
          {
            label: "Onzichtbaar profiel",
            desc: "Je bedrijfsprofiel ziet er niet professioneel uit en overtuigt inkopers niet om verder te klikken."
          },
          {
            label: "Nul inbound leads",
            desc: "Je bent aanwezig, maar er belt niemand vanuit LinkedIn. De investering rendeert niet."
          },
        ].map(item => (
          <div class="warm-card p-7 flex flex-col gap-3">
            <div class="w-10 h-10 rounded-2xl bg-brand-accent/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
              </svg>
            </div>
            <h3 class="text-base font-display font-bold text-brand-primary">{item.label}</h3>
            <p class="text-sm text-brand-ink/70 leading-relaxed font-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4 content pillars — Wat wij doen -->
  <section class="py-24 px-6 bg-[#FFFAF4]">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl mb-14">
        <div class="label-pill">Wat wij bouwen</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-4">
          Vier pijlers.<br />
          <span class="text-brand-accent">Eén autoriteit op LinkedIn.</span>
        </h2>
        <p class="text-lg text-brand-ink/70 leading-relaxed font-light">
          Elke pijler versterkt de andere. Samen bouwen ze een LinkedIn-aanwezigheid die beslissers overtuigt en inbound leads genereert.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Pillar 1: Bedrijfsprofiel -->
        <div class="warm-card p-8 flex flex-col gap-5">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-brand-primary flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <div>
              <div class="text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-0.5">Pijler 1</div>
              <h3 class="text-lg font-display font-bold text-brand-primary leading-tight">Bedrijfsprofiel als commerciële etalage</h3>
            </div>
          </div>
          <p class="text-sm text-brand-ink/70 leading-relaxed font-light">
            Je LinkedIn-pagina is het eerste wat een inkoper ziet nadat hij jouw naam googelt. Wij zorgen dat het overtuigt — van banner en tagline tot beschrijving en aanbevelingen.
          </p>
        </div>

        <!-- Pillar 2: Persoonlijk merk -->
        <div class="warm-card p-8 flex flex-col gap-5 border-brand-accent/20">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-brand-accent flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <div class="text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-0.5">Pijler 2</div>
              <h3 class="text-lg font-display font-bold text-brand-primary leading-tight">Persoonlijk merk van de directeur</h3>
            </div>
          </div>
          <p class="text-sm text-brand-ink/70 leading-relaxed font-light">
            Beslissers kopen van mensen. Het persoonlijke LinkedIn-profiel van de directeur bereikt vaak meer dan de bedrijfspagina. Wij positioneren jou als expert in jouw vakgebied.
          </p>
        </div>

        <!-- Pillar 3: Content -->
        <div class="warm-card p-8 flex flex-col gap-5 border-brand-lime/30">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-brand-lime flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <div>
              <div class="text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-0.5">Pijler 3</div>
              <h3 class="text-lg font-display font-bold text-brand-primary leading-tight">Content die beslissers raakt</h3>
            </div>
          </div>
          <p class="text-sm text-brand-ink/70 leading-relaxed font-light">
            Geen generieke bedrijfsnieuwtjes. Echte inzichten, klantcases en vakkennis — posts die gedeeld worden, reacties uitlokken en jou als autoriteit neerzetten.
          </p>
        </div>

        <!-- Pillar 4: Campagnes -->
        <div class="warm-card p-8 flex flex-col gap-5">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-brand-primary/10 border border-brand-primary/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            <div>
              <div class="text-[10px] font-bold uppercase tracking-widest text-brand-accent mb-0.5">Pijler 4</div>
              <h3 class="text-lg font-display font-bold text-brand-primary leading-tight">Betaalde LinkedIn-campagnes</h3>
            </div>
          </div>
          <p class="text-sm text-brand-ink/70 leading-relaxed font-light">
            Gerichte advertenties op functietitel, sector en bedrijfsgrootte. Voor wie sneller wil bereiken wie telt — zonder zijn budget te verspillen aan de verkeerde doelgroep.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-stappen aanpak — verticaal -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-start">

      <!-- Links: intro tekst -->
      <div class="lg:w-5/12 lg:sticky lg:top-28">
        <div class="label-pill">Hoe wij het aanpakken</div>
        <h2 class="text-3xl lg:text-4xl font-display font-bold text-brand-primary mb-5">
          Consistent aanwezig.<br />
          <span class="text-brand-accent">Met jouw stem.</span>
        </h2>
        <p class="text-lg text-brand-ink/70 leading-relaxed font-light mb-8">
          Wij nemen het LinkedIn-beheer over — van strategie tot publicatie. Alles klinkt als jij, gebouwd op echte kennis van je vakgebied.
        </p>
        <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
          class="btn-primary !py-4 !px-8 text-sm inline-flex w-auto">
          Plan een gesprek
        </a>
      </div>

      <!-- Rechts: stappen -->
      <div class="lg:w-7/12 flex flex-col gap-6">
        {[
          {
            nr: "01",
            title: "LinkedIn-strategie op maat",
            desc: "We bepalen jouw doelgroep, contentkader en toon. Wie wil je bereiken, waarmee overtuig je ze, en hoe klinkt dat als jij? Dat leggen we vast voordat we ook maar één post schrijven."
          },
          {
            nr: "02",
            title: "Profieloptimalisatie",
            desc: "Bedrijfsprofiel en persoonlijk profiel van de directeur — geoptimaliseerd voor zichtbaarheid en geloofwaardigheid. Dit is de basis waarop alles rust."
          },
          {
            nr: "03",
            title: "Maandelijkse contentkalender en publicatie",
            desc: "Elke maand een volledig uitgewerkte kalender: onderwerpen, formats en teksten. Jij keurt goed, wij publiceren. Inclusief visuals in jouw huisstijl."
          },
          {
            nr: "04",
            title: "Rapportage en bijsturing",
            desc: "Maandelijks overzicht van bereik, engagement en leads — en wat we op basis daarvan aanpassen. Geen dashboard dat je zelf moet interpreteren: wij trekken de conclusies."
          },
        ].map((item, i) => (
          <div class="warm-card p-8 flex gap-6 items-start">
            <div class="shrink-0 w-11 h-11 rounded-2xl bg-brand-lime flex items-center justify-center font-display font-black text-brand-primary text-sm">
              {item.nr}
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-brand-primary mb-2">{item.title}</h3>
              <p class="text-sm text-brand-ink/70 leading-relaxed font-light">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Outro / CTA -->
  <section class="py-24 px-6 bg-brand-primary relative overflow-hidden" id="contact">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-white/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[360px] h-[360px] rounded-full bg-brand-lime/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto relative z-10">

      <!-- Sterke slotlijn -->
      <div class="max-w-3xl mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-lime/20 border border-brand-lime/30 rounded-full text-[11px] uppercase tracking-widest font-bold text-brand-lime mb-8">
          LinkedIn-autoriteit opbouwen
        </div>
        <h2 class="text-3xl lg:text-5xl font-display font-bold mb-6 leading-tight tracking-tight text-white">
          Terwijl jij jouw vak uitoefent,<br />
          <span class="text-brand-lime">bouwen wij aan jouw LinkedIn-autoriteit.</span>
        </h2>
        <p class="text-lg text-white/75 leading-relaxed font-light">
          Een beslisser die jouw post ziet, googelt je daarna. Dan belandt hij op je website. Als die niet overtuigt, is hij weg. Wij bouwen LinkedIn, website en SEO als één samenhangend systeem — zodat elke stap in die reis klopt.
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-10 items-start">

        <!-- Garantie-items -->
        <div class="lg:w-[55%] space-y-4">
          {[
            {
              title: "Social + SEO + website als één geheel",
              sub: "LinkedIn brengt ze naar de website, SEO houdt ze vast, sales converteert."
            },
            {
              title: "Eén aanspreekpunt voor alles",
              sub: "Stefan staat voor je klaar. Geen keuzemenu's, geen doorverbinden naar juniors."
            },
            {
              title: "Resultaat of gratis door",
              sub: "Na 6 maanden geen groei? Dan werken we gratis door totdat die er is."
            },
          ].map(item => (
            <div class="flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-2xl">
              <svg class="w-5 h-5 text-brand-lime shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <div>
                <div class="text-sm font-display font-bold text-white mb-0.5">{item.title}</div>
                <div class="text-xs text-white/55 font-light leading-relaxed">{item.sub}</div>
              </div>
            </div>
          ))}

          <div class="pt-4">
            <a href="https://meetings-eu1.hubspot.com/stefan-kelderman" target="_blank" rel="noreferrer"
              class="inline-flex items-center gap-2 px-10 py-5 bg-brand-accent text-white rounded-2xl font-display font-bold transition-all hover:scale-[1.02] shadow-xl text-base w-full sm:w-auto justify-center">
              Plan je gratis analyse
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <p class="mt-4 text-[10px] font-bold uppercase tracking-[0.3em] text-white/40">Stefan staat zelf voor je klaar — max 4 nieuwe klanten per maand</p>
          </div>
        </div>

        <!-- Stats blok -->
        <div class="lg:w-[45%] w-full">
          <div class="bg-white/5 border border-white/10 rounded-[28px] p-10">
            <div class="text-brand-lime text-[10px] font-bold uppercase tracking-widest mb-8">Gemiddeld na 6 maanden samenwerking</div>
            <div class="space-y-8">
              <div>
                <div class="text-5xl font-display font-black text-white mb-1">5<span class="text-brand-accent text-2xl ml-1">x</span></div>
                <div class="text-sm text-white/55 font-light">meer LinkedIn-bereik</div>
              </div>
              <div class="h-px bg-white/10"></div>
              <div>
                <div class="text-5xl font-display font-black text-white mb-1">3<span class="text-brand-accent text-2xl ml-1">x</span></div>
                <div class="text-sm text-white/55 font-light">meer inbound aanvragen</div>
              </div>
              <div class="h-px bg-white/10"></div>
              <div>
                <div class="text-5xl font-display font-black text-white mb-1">30<span class="text-brand-accent text-2xl ml-1">d</span></div>
                <div class="text-sm text-white/55 font-light">van gesprek naar live systeem</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</ServiceLayout>
