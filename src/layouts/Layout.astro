---
import {
  buildGoogleTagScript,
  buildTagManagerScript,
  getGoogleTrackingSettings,
} from '../lib/google-tracking';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  publishedTime?: string;
  author?: string;
  faqSchema?: string;
  articleSchema?: string;
  breadcrumbSchema?: string;
}

const {
  title = 'Optimaal Groeien — B2B Commercie voor Industrie & Techniek',
  description = 'Wij runnen de commerciële structuur van B2B-bedrijven in industrie, machinebouw, logistiek en bouw. Voorspelbare groei via AI, branding, marketing & sales.',
  canonical = 'https://optimaalgroeien.nl/',
  ogImage = 'https://optimaalgroeien.nl/images/team-full.jpg',
  ogType = 'website',
  noindex = false,
  publishedTime,
  author,
  faqSchema,
  articleSchema,
  breadcrumbSchema,
} = Astro.props;

// Normalize canonical: always include trailing slash to match Astro's URL output
// (prevents canonical → 307 redirect → final URL chain)
const canonicalUrl = canonical.endsWith('/') ? canonical : canonical + '/';
const googleTracking = await getGoogleTrackingSettings();
const tagManagerScript = googleTracking.enabled && googleTracking.type === 'gtm'
  ? buildTagManagerScript(googleTracking.id)
  : '';
const googleTagScript = googleTracking.enabled && googleTracking.type === 'google-tag'
  ? buildGoogleTagScript(googleTracking.id)
  : '';

// Organization schema (on every page) — required for Knowledge Graph + AI citations
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Optimaal Groeien",
  "url": "https://optimaalgroeien.nl/",
  "logo": "https://optimaalgroeien.nl/images/logo.webp",
  "description": "Commercieel partner voor B2B-bedrijven in industrie, machinebouw, logistiek en bouw. Branding, marketing en sales als geïntegreerd systeem.",
  "sameAs": [
    "https://www.linkedin.com/company/optimaal-groeien/",
  ],
};

// WebSite schema (on every page)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Optimaal Groeien",
  "url": "https://optimaalgroeien.nl/",
  "inLanguage": "nl-NL",
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Self-hosted fonts -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
    {tagManagerScript && <script is:inline data-og-google-tracking="gtm" set:html={tagManagerScript} />}
    {googleTagScript && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleTracking.id}`} data-og-google-tracking="google-tag"></script>
        <script is:inline data-og-google-tracking="google-tag-config" set:html={googleTagScript} />
      </>
    )}
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1600" />
    <meta property="og:image:height" content="1143" />
    <meta property="og:locale" content="nl_NL" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
    {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
    <!-- Structured data — Organization + WebSite (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Leadinfo -->
    <script is:inline>
      (function (w, d, n, id) {
        w.GlobalLeadinfoNamespace = w.GlobalLeadinfoNamespace || [];
        w.GlobalLeadinfoNamespace.push(n);
        w[n] = w[n] || function () {
          (w[n].q = w[n].q || []).push(arguments);
        };
        w[n].t = id;
        w[n].q = w[n].q || [];

        var firstScript = d.getElementsByTagName('script')[0];
        var script = d.createElement('script');
        script.async = true;
        script.id = 'LeadinfoTracking';
        script.src = 'https://cdn.leadinfo.net/ping.js';
        firstScript.parentNode.insertBefore(script, firstScript);
      })(window, document, 'leadinfo', 'LI-618941BAAC746');
    </script>
  </head>
  <body>
    {tagManagerScript && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${googleTracking.id}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        ></iframe>
      </noscript>
    )}
    <slot />
  </body>
</html>
