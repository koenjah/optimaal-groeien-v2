---
import Layout from './Layout.astro';
import { NavbarBlog } from '../components/NavbarBlog';
import { Footer } from '../components/SiteComponents';
import '../index.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  publishedTime?: string;
  author?: string;
}

const { title, description, canonical, ogImage, ogType, noindex, publishedTime, author } = Astro.props;
---

<Layout {title} {description} {canonical} {ogImage} {ogType} {noindex} {publishedTime} {author}>
  <NavbarBlog client:load />
  <slot />
  <Footer client:load />
</Layout>
